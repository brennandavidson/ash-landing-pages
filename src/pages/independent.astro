  <script>
    const floatingCta = document.getElementById('floating-cta');
    const hero = document.querySelector('main > section');

    function checkScroll() {
      if (!hero || !floatingCta) return;
      const heroBottom = hero.offsetTop + hero.offsetHeight;
      const scrollY = window.scrollY;
      if (scrollY > heroBottom - 100) {
        floatingCta.style.opacity = '1';
        floatingCta.style.visibility = 'visible';
      } else {
        floatingCta.style.opacity = '0';
        floatingCta.style.visibility = 'hidden';
      }
    }

    floatingCta?.addEventListener('mouseenter', function() {
      this.style.transform = 'translateY(-3px)';
      this.style.boxShadow = '0 8px 30px rgba(228,47,58,0.5)';
    });

    floatingCta?.addEventListener('mouseleave', function() {
      this.style.transform = 'none';
      this.style.boxShadow = '0 4px 20px rgba(228,47,58,0.4)';
    });

    window.addEventListener('scroll', checkScroll);
    checkScroll();
  </script>

  <!-- Form Submission -->
  <script>
    const form = document.getElementById('estimate-form');
    const submitBtn = document.getElementById('estimate-submit-btn');
    const formSuccess = document.getElementById('estimate-form-success');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';
      submitBtn.style.opacity = '0.7';

      const formData = new FormData(form);
      const data = {};

      formData.forEach((value, key) => {
        if (key === 'terms_and_conditions') {
          data[key] = 'I Agree';
        } else {
          data[key] = value;
        }
      });

      if (window.ashAttribution) {
        const attr = window.ashAttribution.getForForm();
        Object.assign(data, attr);
      }

      // Fire-and-forget: log this as a website lead so the HCP webhook
      // can dedupe and skip the offline CAPI fire for this same person.
      fetch('/api/website-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          phone: data.phone,
          source_url: window.location.href,
        }),
      }).catch(() => {});

      try {
        const response = await fetch('https://services.leadconnectorhq.com/hooks/dGHA224kB5WE4OS1KLqw/webhook-trigger/N6yAhFamR7YZzWNoTMeM', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          if (window.ashAttribution) {
            window.ashAttribution.trackFormSubmit('antipe_independent_form');
          }
          form.style.display = 'none';
          formSuccess.style.display = 'block';
        } else {
          throw new Error('Submission failed');
        }
      } catch (error) {
        console.error('Form submission error:', error);
        alert('Something went wrong. Please try again or call us directly.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'GET MY NO-PRESSURE ESTIMATE →';
        submitBtn.style.opacity = '1';
      }
    });

    document.querySelectorAll('#estimate-form input, #estimate-form select').forEach(el => {
      el.addEventListener('focus', () => {
        el.style.borderColor = '#E42F3A';
        el.style.outline = 'none';
      });
      el.addEventListener('blur', () => {
        el.style.borderColor = '#e0e0e0';
      });
    });

    document.querySelectorAll('#estimate-form select').forEach(selectEl => {
      selectEl.addEventListener('change', () => {
        selectEl.style.color = '#1a1a1a';
      });
    });
  </script>
