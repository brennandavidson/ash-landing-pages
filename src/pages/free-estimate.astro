            onmouseout="this.style.transform='none'; this.style.boxShadow='0 4px 15px rgba(228,47,58,0.3)';"
          >
            Get My Free Estimate →
          </a>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section style="background: #1a1a1a; padding: 5rem 0;">
      <div style="max-width: 800px; margin: 0 auto; padding: 0 1.5rem; text-align: center;">
        <h2 style="font-size: clamp(2.5rem, 6vw, 4rem); color: #ffffff; margin-bottom: 1rem;">
          Get A New AC <span style="color: #E42F3A;">Before It Breaks.</span>
        </h2>
        <p style="color: rgba(255,255,255,0.7); font-size: 1.375rem; margin-bottom: 2.5rem;">
          Free in-home estimate. As low as $150/mo with 0% APR financing. We beat big name quotes.
        </p>
        <a
          href="#form"
          style="display: inline-block; background-color: #E42F3A; color: #ffffff; padding: 1.25rem 3rem; font-size: 1.25rem; font-weight: 700; text-decoration: none; border-radius: 4px; box-shadow: 0 4px 20px rgba(228,47,58,0.4); transition: all 0.2s;"
          onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 30px rgba(228,47,58,0.5)';"
          onmouseout="this.style.transform='none'; this.style.boxShadow='0 4px 20px rgba(228,47,58,0.4)';"
        >
          Get My Free Estimate →
        </a>
      </div>
    </section>
  </main>

  <Footer phone={phone} />

  <!-- Floating CTA Button -->
  <a
    id="floating-cta"
    href="#form"
    style="position: fixed; bottom: 1.5rem; right: 1.5rem; background-color: #E42F3A; color: #ffffff; padding: 1rem 1.5rem; font-size: 1rem; font-weight: 700; text-decoration: none; border-radius: 50px; box-shadow: 0 4px 20px rgba(228,47,58,0.4); z-index: 1000; opacity: 0; visibility: hidden; transition: all 0.3s ease; display: flex; align-items: center; gap: 0.5rem;"
  >
    <span>Free Estimate</span>
    <svg style="width: 18px; height: 18px;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </a>

  <script>
    const floatingCta = document.getElementById('floating-cta');
    const hero = document.querySelector('main > section');

    function checkScroll() {
      if (!hero || !floatingCta) return;
      const heroBottom = hero.offsetTop + hero.offsetHeight;
      const scrollY = window.scrollY;
      if (scrollY > heroBottom - 100) {
        floatingCta.style.opacity = '1';
        floatingCta.style.visibility = 'visible';
      } else {
        floatingCta.style.opacity = '0';
        floatingCta.style.visibility = 'hidden';
      }
    }

    floatingCta?.addEventListener('mouseenter', function() {
      this.style.transform = 'translateY(-3px)';
      this.style.boxShadow = '0 8px 30px rgba(228,47,58,0.5)';
    });

    floatingCta?.addEventListener('mouseleave', function() {
      this.style.transform = 'none';
      this.style.boxShadow = '0 4px 20px rgba(228,47,58,0.4)';
    });

    window.addEventListener('scroll', checkScroll);
    checkScroll();
  </script>

  <!-- Form Submission -->
  <script>
    const form = document.getElementById('estimate-form');
    const submitBtn = document.getElementById('estimate-submit-btn');
    const formSuccess = document.getElementById('estimate-form-success');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';
      submitBtn.style.opacity = '0.7';

      const formData = new FormData(form);
      const data = {};

      formData.forEach((value, key) => {
        if (key === 'terms_and_conditions') {
          data[key] = 'I Agree';
        } else {
          data[key] = value;
        }
      });

      if (window.ashAttribution) {
        const attr = window.ashAttribution.getForForm();
        Object.assign(data, attr);
      }

      try {
        const response = await fetch('https://services.leadconnectorhq.com/hooks/dGHA224kB5WE4OS1KLqw/webhook-trigger/847113cf-e966-43b5-8d23-12f67951d14a', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          if (window.ashAttribution) {
            window.ashAttribution.trackFormSubmit('pre115_urgency_form');
          }
          form.style.display = 'none';
          formSuccess.style.display = 'block';
        } else {
          throw new Error('Submission failed');
        }
      } catch (error) {
        console.error('Form submission error:', error);
        alert('Something went wrong. Please try again or call us directly.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'GET MY FREE ESTIMATE →';
        submitBtn.style.opacity = '1';
      }
    });

    document.querySelectorAll('#estimate-form input, #estimate-form select').forEach(el => {
      el.addEventListener('focus', () => {
        el.style.borderColor = '#E42F3A';
        el.style.outline = 'none';
      });
      el.addEventListener('blur', () => {
        el.style.borderColor = '#e0e0e0';
      });
    });

    const selectEl = document.querySelector('#estimate-form select');
    selectEl?.addEventListener('change', () => {
      selectEl.style.color = '#1a1a1a';
    });
  </script>
</Layout>

